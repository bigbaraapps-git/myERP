generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// --- Multi-Tenancy & Subscriptions ---

model Company {
  id             String      @id @default(cuid())
  name           String
  oib            String      @unique
  address        String?
  city           String?
  country        String      @default("HR")
  legalType      String      // jdoo, doo, d.d, Obrt
  
  // Subscription
  package        PackageType @default(TRIAL)
  packageExpires DateTime?
  invoiceLimit   Int?        // Null for unlimited
  
  // Relations
  users          User[]
  clients        Client[]
  employees      Employee[]
  offers         Offer[]
  invoices       Invoice[]
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

enum PackageType {
  TRIAL
  BUSINESS_STANDARD
  BUSINESS_PREMIUM
  BUSINESS_CUSTOM
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  role      Role      @default(USER)
  
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum Role {
  USER
  ADMIN
  OWNER
  SUPERADMIN
}

// --- CRM & Employee Management ---

model Employee {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  email     String?
  status    EmpStatus @default(ACTIVE)
  jobTitle  String?
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum EmpStatus {
  ACTIVE
  VACATION
  SICK_LEAVE
  INACTIVE
  TERMINATED
}

model Client {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  oib       String?
  email     String?
  phone     String?
  address   String?
  city      String?
  country   String    @default("HR")
  
  offers    Offer[]
  invoices  Invoice[]
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// --- Sales Workflow ---

model Offer {
  id          String      @id @default(cuid())
  number      String      // e.g., OFF-2024-001
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id])
  clientId    String
  client      Client      @relation(fields: [clientId], references: [id])
  
  status      OfferStatus @default(DRAFT)
  issueDate   DateTime    @default(now())
  validUntil  DateTime
  
  currency    String      @default("EUR")
  totalNet    Float
  totalTax    Float
  totalGross  Float
  
  items       OfferItem[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum OfferStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  INVOICED
  EXPIRED
}

model OfferItem {
  id          String  @id @default(cuid())
  offerId     String
  offer       Offer   @relation(fields: [offerId], references: [id])
  description String
  quantity    Float
  unitPrice   Float
  taxRate     Float   @default(25)
  total       Float
}

model Invoice {
  id              String      @id @default(cuid())
  number          String      // e.g., 1/1/1
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id])
  clientId        String
  client          Client      @relation(fields: [clientId], references: [id])
  
  status          InvoiceStatus @default(DRAFT)
  issueDate       DateTime      @default(now())
  dueDate         DateTime
  
  totalNet        Float
  totalTax        Float
  totalGross      Float
  
  // Fiskalizacija 2.0
  fiskalizationId String?     // JIR from Fiskal service
  zki             String?
  kpdCode         String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}
